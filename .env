# ==============================================================
# CupomSmart MG — Variáveis de Ambiente
# ==============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ==============================================================

# --------------------------------------------------------------
# Supabase (frontend) — obter em: supabase.com → Project Settings → API
# --------------------------------------------------------------
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...  # anon/public key
VITE_SUPABASE_PROJECT_ID=SEU_PROJECT_ID

# --------------------------------------------------------------
# Secrets das Edge Functions
# Configurar em: Lovable Dashboard → Secrets (ou supabase secrets set)
# Estes valores NUNCA vão no .env do frontend — são server-side only
# --------------------------------------------------------------

# Firecrawl — https://firecrawl.dev
# Usado por: fetch-nfce, search-amazon, search-mercadolivre, search-ifood
# FIRECRAWL_API_KEY=fc-...

# Lovable AI Gateway (Gemini Flash) — gerenciado automaticamente pelo Lovable
# Usado por: ai-product-intelligence
# LOVABLE_API_KEY=...

# Supabase service role — NÃO expor no frontend
# Injetado automaticamente nas edge functions pelo Lovable/Supabase
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
# SUPABASE_DB_URL=postgresql://postgres:...
